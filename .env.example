# ===========================================
# Переменные окружения для локальной разработки
# Скопируйте этот файл в .env и настройте при необходимости
# ===========================================

# ===========================================
# PostgreSQL
# ===========================================
DB_URL=jdbc:postgresql://localhost:5432/filter_db
DB_USERNAME=filter
DB_PASSWORD=filter

# ===========================================
# Kafka Bootstrap Servers
# ===========================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092,localhost:9094,localhost:9096

# ===========================================
# Filter Service
# ===========================================
FILTER_SERVICE_HTTP_PORT=8081
FILTER_SERVICE_PRIVATE_PORT=8086

# ===========================================
# Outbox Sender
# ===========================================
OUTBOX_SENDER_HTTP_PORT=9099
OUTBOX_SENDER_PRIVATE_PORT=9089

# ===========================================
# Data Processor
# ===========================================
DATA_PROCESSOR_HTTP_PORT=8082
DATA_PROCESSOR_PRIVATE_PORT=8087

# ===========================================
# Alert Service
# ===========================================
ALERT_SERVICE_HTTP_PORT=8090
ALERT_SERVICE_WS_PORT=7818
